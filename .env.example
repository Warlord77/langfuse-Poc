# Copy this file to ".env" and fill in your LOCAL Langfuse keys.
# Get them from http://localhost:3000 -> your project -> Settings -> API Keys

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Optional: leave OPENAI_API_KEY unset to use the built-in deterministic mock LLM
# (every stage runs fully without it). Set it to use a real model instead.
# OPENAI_API_KEY=sk-...
# MODEL_NAME=gpt-4o-mini

# Optional: identify the user in Sessions/Users views
# DEMO_USER_ID=demo-user
